# vex configuration
# Copy to ~/.vex/config.yaml or ./config.yaml and adjust as needed

api:
  key: ""              # or set VT_API_KEY env var
  tier: "free"         # "free" (4 req/min) or "premium" (1000 req/min)

cache:
  enabled: true
  ttl_hours: 24        # cache TTL in hours
  # db_path: ~/.vex/cache.db

output:
  default_format: json # json | rich | console
  quiet: false         # suppress banner (-q)
