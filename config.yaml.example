# vex configuration example
# Copy to ~/.vex/config.yaml and adjust as needed

api:
  # API key — set here OR use environment variable VT_API_KEY
  # key: "your-virustotal-api-key-here"
  tier: free  # free | premium

  rate_limit:
    free:
      requests_per_minute: 4
      requests_per_day: 500
    premium:
      requests_per_minute: 1000
      requests_per_day: 50000

thresholds:
  # Minimum engine detections for MALICIOUS verdict
  malicious_min_detections: 3
  # Minimum engine detections for SUSPICIOUS verdict
  suspicious_min_detections: 1
  # Zero detections = UNKNOWN (not CLEAN) if analysis_count < this
  min_engines_for_clean: 10

cache:
  enabled: true
  ttl_hours: 24
  # Cache DB path (default: ~/.vex/cache.db)
  # db_path: "~/.vex/cache.db"

output:
  # Default output format: json | rich | console
  default_format: json
  # Suppress ASCII banner (-q)
  quiet: false

plugins:
  # Enable loading plugins from ~/.vex/plugins/
  load_local: false

update_check:
  # Check for new releases on PyPI
  enabled: true
  check_interval_hours: 24

ai:
  # AI provider for --explain: none | anthropic | openai | ollama
  provider: none
  # Model override (default per provider: claude-sonnet-4-20250514, gpt-4o, llama3)
  # model: "claude-sonnet-4-20250514"
  # API key — set here OR use environment variable VEX_AI_API_KEY
  # api_key: "your-ai-api-key-here"
  # Base URL for Ollama (default: http://localhost:11434)
  # base_url: "http://localhost:11434"
  max_tokens: 500
  temperature: 0.3
  # When true, only allow local providers (ollama). Blocks anthropic/openai.
  local_only: false
  # Cache AI responses (hours). Set to 0 to disable.
  cache_ttl_hours: 72

enrichment:
  # Direct WHOIS lookup for domain IOCs (investigate mode).
  # Supplements VT premium WHOIS — works for free-tier users too.
  # python-whois is included in the base install (core dependency).
  whois_enabled: true
